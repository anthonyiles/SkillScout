{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://github.com/*" }]
    },
    "dialog:allow-open",
    "updater:default",
    "process:allow-restart"
  ]
}