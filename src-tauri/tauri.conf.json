{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillScout",
  "version": "0.2.0",
  "identifier": "com.skillscout.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillScout",
        "width": 1100,
        "height": 750
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://api.github.com https://raw.githubusercontent.com; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none';"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://skillscout-update.iles.sh?channel=stable"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDEwMjM2Q0Q2QjlCMDY3MUQKUldRZFo3QzUxbXdqRUlDR09pRDQ4djNvWFd2SHhpVGZrekFDcFZZVDg4NVpxTE12RHFaYUlnMXYK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}