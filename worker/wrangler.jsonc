{
  "name": "skillscout-update",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-28",
  "vars": {
    "GITHUB_REPO": "anthonyiles/SkillScout"
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true
    }
  }
  // Store the GitHub token as a secret (never in this file):
  // wrangler secret put GITHUB_TOKEN
}
